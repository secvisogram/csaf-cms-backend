# Configuration for the csaf-cms-backend application. Read directly by "./mvnw spring-boot:run"
# and passed into the container via env_file in docker/compose.yaml.
#
# For local docker compose orchestration settings (Keycloak, oauth2-proxy, CouchDB credentials,
# ports, ...), see docker/.env.example instead.
#
# All variables are commented out with their default (see application.properties). Uncomment
# only what you need to change. Copy this file to ".env" to use it.

# CSAF_CMS_BACKEND_PORT=8081
# CSAF_CMS_BACKEND_CSRF_ENABLED=true

# CouchDB connection used by the backend when running standalone (./mvnw spring-boot:run).
# CSAF_COUCHDB_HOST=localhost
# CSAF_COUCHDB_PORT=5984
# CSAF_COUCHDB_SSL=false
# CSAF_COUCHDB_DBNAME=csaf
# CSAF_COUCHDB_USER=admin
# CSAF_COUCHDB_PASSWORD=admin

# keycloak
# CSAF_OIDC_ISSUER_URL=http://localhost/realms/csaf
# CSAF_OIDC_JWKS_URL=

# document templates
# CSAF_TEMPLATES_FILE=./templates/allTemplates.json
# CSAF_COMPANY_LOGO_PATH=

# versioning strategy: Integer or Semantic
# CSAF_VERSIONING=Semantic

# revision history summary an workflow changes
# CSAF_SUMMARY_PUBLICATION=Initial Publication

# validation
# CSAF_VALIDATION_BASE_URL=http://localhost/validate/api/v1/

# max. levenshtein distance between changed values in the csaf document to decide whether a change is a patch or a minor change
# CSAF_VERSIONING_LEVENSHTEIN=4

# Base URL (of the server hosting the documents)
# CSAF_REFERENCES_BASE_URL=http://example.com
# Company code in the temporary tracking id
# CSAF_TRACKINGID_COMPANY=ExampleInc
# Number of digits of the sequential number of the tracking id. Missing digits are filled with zeros
# CSAF_TRACKINGID_DIGITS=5

# autopublish settings
# CSAF_AUTOPUBLISH_INSECURETLS=false
# CSAF_AUTOPUBLISH_URL=http://localhost/cgi-bin/csaf_provider.go/api/upload
# CSAF_AUTOPUBLISH_PASSWORD=secretpassword
# CSAF_AUTOPUBLISH_CRON=0 * * * * *

# workflow settings
# CSAF_WORKFLOW_ALLOW_OWN_DOCUMENTS_APPROVED=false
