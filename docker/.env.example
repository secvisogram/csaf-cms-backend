# create a copy of this file as .env in the same directory and fill in the values to configure the
# local docker compose stack.

CSAF_VALIDATOR_PORT=8082
# docker compose uses the service name to connect to the backend container.
CSAF_CMS_BACKEND_HOST=backend-cms
# For debugging, stop that container, set CSAF_CMS_BACKEND_HOST=host.docker.internal in .env, and restart this service.
#CSAF_CMS_BACKEND_HOST=host.docker.internal
# Must match CSAF_CMS_BACKEND_PORT in the repo root's .env (used here for the port mapping of the
# csaf-cms-backend service and as the port oauth2-proxy forwards to).
CSAF_CMS_BACKEND_PORT=8081

# CouchDB container credentials.
CSAF_COUCHDB_PORT=5984
CSAF_COUCHDB_SSL=false
CSAF_COUCHDB_DBNAME=csaf
CSAF_COUCHDB_USER=admin
CSAF_COUCHDB_PASSWORD=admin

# Keycloak
CSAF_KEYCLOAK_PORT=9000
CSAF_KEYCLOAK_DATABASE_PORT=5432
CSAF_KEYCLOAK_DATABASE_NAME=keycloak
CSAF_KEYCLOAK_DATABASE_USER=keycloak
CSAF_KEYCLOAK_DATABASE_PASSWORD=keycloak
CSAF_KEYCLOAK_ADMIN_USER=admin
CSAF_KEYCLOAK_ADMIN_PASSWORD=admin
CSAF_KEYCLOAK_CLIENT_HOSTNAME=http://localhost
CSAF_KEYCLOAK_ADMIN_HOSTNAME=http://localhost

# Auth Proxy
CSAF_REALM=csaf
CSAF_APP_EXTERNAL_PROTOCOL=http
CSAF_APP_EXTERNAL_HOSTNAME=localhost
CSAF_APP_EXTERNAL_PORT=4180

CSAF_CLIENT_ID=secvisogram
# Fixed dev-only secret for the "secvisogram" Keycloak client.
# If you change it after the first start, delete docker/data/keycloak-db to re-import the realm.
CSAF_CLIENT_SECRET=dev-only-3f8a1c7e2b9d4f6a0e5c8b3d7a1f9e2c
# https://oauth2-proxy.github.io/oauth2-proxy/configuration/overview/#generating-a-cookie-secret
CSAF_COOKIE_SECRET=
